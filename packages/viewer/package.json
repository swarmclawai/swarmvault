{
  "name": "@swarmvaultai/viewer",
  "version": "0.7.23",
  "description": "Graph viewer package for SwarmVault graph artifacts.",
  "type": "module",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swarmclawai/swarmvault.git"
  },
  "homepage": "https://www.swarmvault.ai",
  "bugs": {
    "url": "https://github.com/swarmclawai/swarmvault/issues"
  },
  "keywords": [
    "swarmvault",
    "viewer",
    "graph",
    "cytoscape",
    "knowledge-base",
    "local-first"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:app",
    "build:lib": "tsup src/lib.ts --format esm --dts --out-dir dist --clean",
    "build:app": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node ../../scripts/check-release-sync.mjs && node ../../scripts/check-published-manifests.mjs"
  },
  "dependencies": {
    "cytoscape": "^3.33.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
