{
  "name": "@swarmvaultai/engine",
  "version": "0.7.25",
  "description": "Core engine for SwarmVault: ingest, compile, query, lint, and provider abstractions.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swarmclawai/swarmvault.git"
  },
  "homepage": "https://www.swarmvault.ai",
  "bugs": {
    "url": "https://github.com/swarmclawai/swarmvault/issues"
  },
  "keywords": [
    "swarmvault",
    "llm",
    "knowledge-base",
    "markdown",
    "obsidian",
    "graph",
    "search",
    "local-first"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "test -f ../viewer/dist/index.html || pnpm --dir ../viewer build; tsup src/index.ts --format esm --dts && tsup --config tsup.hooks.config.ts && rm -rf dist/viewer && mkdir -p dist/viewer && cp -R ../viewer/dist/. dist/viewer/",
    "pretest": "tsup --config tsup.hooks.config.ts",
    "test": "SWARMVAULT_ALLOW_PRIVATE_URLS=1 vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node ../../scripts/check-release-sync.mjs && node ../../scripts/check-published-manifests.mjs"
  },
  "dependencies": {
    "@asciidoctor/core": "^3.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@retorquere/bibtex-parser": "^9.0.29",
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "chokidar": "^4.0.3",
    "compromise": "^14.14.4",
    "csv-parse": "^6.2.1",
    "fast-xml-parser": "^5.5.11",
    "fflate": "^0.8.2",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "ini": "^6.0.0",
    "istextorbinary": "^9.5.0",
    "jsdom": "^27.0.0",
    "mailparser": "^3.9.8",
    "mammoth": "^1.12.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mime-types": "^3.0.1",
    "neo4j-driver": "^5.28.3",
    "node-ical": "^0.26.0",
    "node-mbox": "^2.0.0",
    "orga": "^4.7.1",
    "pdfjs-dist": "^5.4.394",
    "rtf-parser": "^1.3.3",
    "smol-toml": "^1.6.1",
    "subtitle": "^4.2.2",
    "tree-sitter-wasms": "^0.1.13",
    "turndown": "^7.2.1",
    "typescript": "^5.9.3",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/ini": "^4.1.1",
    "@types/jsdom": "^27.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.6.0",
    "@types/turndown": "^5.0.5",
    "graphology-types": "^0.24.8",
    "tsup": "^8.5.0",
    "vitest": "^3.2.4"
  }
}
