{
  "name": "@swarmvaultai/engine",
  "version": "0.1.32",
  "description": "Core engine for SwarmVault: ingest, compile, query, lint, and provider abstractions.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swarmclawai/swarmvault.git"
  },
  "homepage": "https://www.swarmvault.ai",
  "bugs": {
    "url": "https://github.com/swarmclawai/swarmvault/issues"
  },
  "keywords": [
    "swarmvault",
    "llm",
    "knowledge-base",
    "markdown",
    "obsidian",
    "graph",
    "search",
    "local-first"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "test -f ../viewer/dist/index.html || pnpm --dir ../viewer build; tsup src/index.ts --format esm --dts && rm -rf dist/viewer && mkdir -p dist/viewer && cp -R ../viewer/dist/. dist/viewer/",
    "test": "SWARMVAULT_ALLOW_PRIVATE_URLS=1 vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "chokidar": "^4.0.3",
    "fflate": "^0.8.2",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "jsdom": "^27.0.0",
    "mammoth": "^1.12.0",
    "mime-types": "^3.0.1",
    "neo4j-driver": "^5.28.3",
    "pdfjs-dist": "^5.4.394",
    "turndown": "^7.2.1",
    "typescript": "^5.9.3",
    "yaml": "^2.8.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.6.0",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.5.0",
    "vitest": "^3.2.4"
  }
}
