{
  "name": "@swarmvaultai/engine",
  "version": "0.1.1",
  "description": "Core engine for SwarmVault: ingest, compile, query, lint, and provider abstractions.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swarmclawai/swarmvault.git"
  },
  "homepage": "https://swarmvault.ai",
  "bugs": {
    "url": "https://github.com/swarmclawai/swarmvault/issues"
  },
  "keywords": [
    "swarmvault",
    "llm",
    "knowledge-base",
    "markdown",
    "obsidian",
    "graph",
    "search",
    "local-first"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@swarmvaultai/viewer": "workspace:*",
    "gray-matter": "^4.0.3",
    "jsdom": "^27.0.0",
    "mime-types": "^3.0.1",
    "turndown": "^7.2.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.6.0",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.5.0",
    "vitest": "^3.2.4"
  }
}
