{
  "name": "@swarmvaultai/cli",
  "version": "0.1.32",
  "description": "Global CLI for SwarmVault.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swarmclawai/swarmvault.git"
  },
  "homepage": "https://www.swarmvault.ai",
  "bugs": {
